# Copy this file to .env for local development. Never commit .env.

# Your Discord bot token (from the Developer Portal → Bot → Token)
DISCORD_TOKEN=your-bot-token-here

# PostgreSQL connection string
# On Railway this is injected automatically when you add a Postgres database.
# For local dev, spin up a local Postgres instance or use a free cloud one (e.g. Neon.tech).
DATABASE_URL=postgresql://user:password@localhost:5432/guardbot
